# Investor_App_DMD — public-safe example env
# Diese Datei enthält NUR öffentliche, optionale Frontend-Variablen.
# Keine Secrets, keine API-Keys, keine Wallet-Dateien.
# On-chain Wahrheit wird NICHT per ENV überschrieben.

# Optional:
# Öffentlicher, keyloser RPC-Endpunkt.
# Leer lassen = App nutzt den in App.tsx hinterlegten Fallback.
VITE_RPC_URL=https://api.mainnet-beta.solana.com

# Optional:
# Backend nur aktivieren, wenn wirklich ein Proxy / Worker / Edge-Service existiert.
# 0 = aus, 1 = an
VITE_BACKEND_ENABLED=0

# Optional:
# Absolute Backend-URL, z. B.:
# https://your-worker.example.workers.dev
# Leer lassen, wenn kein Backend genutzt wird.
VITE_BACKEND_URL=

# Optional:
# Zusätzliche Preisquelle nur bei Bedarf aktivieren.
# 0 = aus, 1 = an
VITE_ALLOW_COINGECKO=0

# Optional:
# Pyth Hermes Feed ID für SOL/USD, nur wenn bewusst genutzt.
VITE_PYTH_SOL_USD_ID=